<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My music collection</title>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body>
    <h1> My Music Collection</h1>

    <div class="search-box">
        <input type="text" id="search" placeholder="Search your songs...">
    </div>

    <div class="song-list" id="songList">
        <% songs.forEach(song =>{%>
            <div class="song-item">
                <p><%=song%></p>
                <button onclick="playSong('/uploads/<%=song%>')">▶</button>
            </div>
        <%}) %>
    </div>

    <div class="audio-player">
        <audio id="audioPlayer" controls></audio>
    </div>

    <a href="/upload" class="upload-link">⬆ Upload New Song</a>

    <script src="/public/script.js"></script>
</body>
</html>